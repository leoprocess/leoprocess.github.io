@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var enum_code_type_id = "";
            var codetable_query_url = "@Url.Action("QueryCodeTables", "System")";
            var codetable_delete_url = "@Url.Action("DeleteCodeTables", "System")";
            var codetable_update_url = "@Url.Action("UpdateCodeTable", "System")";
            var codetype_dropdown_url = "@Url.Action("QueryDropDownCodeType", "System")";
            var relation_query_filter_url = "@Url.Action("QueryRelationFilters", "System")";
            var isQuery = @isQuery.ToString().ToLower();

            //#region 主畫面

            //#region 初始代碼表格
            $(".code-grid").kendoGrid({
                dataSource: {
                    sort: { field: "OrderNo", dir: "asc" },
                    transport: {
                        read: {
                            contentType: "application/json",
                            dataType: "json",
                            type: "post",
                            url: codetable_query_url,
                        }
                    },
                    schema: {
                        model: {
                            fields: {
                                CreateDateTime: { type: "date" },
                                ModifyDateTime: { type: "date" }
                            }
                        },
                        data: "Data",
                        total: "Total",
                        errors: "Errors"
                    },
                    filter: { field: "ParentCodeTableId", operator: "eq", value: null }
                },
                detailInit: function (e) {
                    $("<div/>").appendTo(e.detailCell).addClass("sub-grid").data("parent-code-table-id", e.data.CodeTableId).data("parent-code-table-name", e.data.Name).kendoGrid({
                        dataSource: {
                            sort: { field: "OrderNo", dir: "asc" },
                            data: $(".code-grid").data("kendoGrid").dataSource.data(),
                            filter: { field: "ParentCodeTableId", operator: "eq", value: e.data.CodeTableId }
                        },
                        dataBound: function () {
                            initialToolbar();
                        },
                        scrollable: false,
                        sortable: true,
                        selectable: "multiple, row",
                        toolbar: kendo.template($("#toolbar-template").html()),
                        columns: $(".code-grid").data("kendoGrid").columns
                    });
                },
                dataBound: function () {
                    this.expandRow(this.tbody.find("tr.k-master-row").first());

                    //參數項目不需展開子項
                    var data = this.dataSource.data();

                    $.each(data, function (i, row) {
                        if (row.get("CodeTypeId") != enum_code_type_id)
                            $('tr[data-uid="' + row.uid + '"] ').find(".k-hierarchy-cell a").remove();
                        if (row.IsReadOnly) {
                            $('tr[data-uid="' + row.uid + '"] ').find("input[type=checkbox]").remove();
                            $('tr[data-uid="' + row.uid + '"] ').removeClass("k-state-selected");
                        }
                    });
                },
                autoBind: false,
                scrollable: true,
                sortable: true,
                toolbar: kendo.template($("#toolbar-template").html()),
                columns: [{
                        selectable: true,
                        width: 52
                    }, {
                        template: kendo.template($("#command-template").html()),
                        title: "關連設定",
                        width: 110
                    }, {
                        field: "CodeType",
                        title: "代碼類型",
                        width: 120
                    }, {
                        field: "Code",
                        title: "代碼",
                        width: 240
                    }, {
                        field: "Name",
                        title: "名稱/設定值",
                        width: 150
                    }, {
                        field: "Memo",
                        title: "說明"
                    }, {
                        field: "OrderNo",
                        title: "順序",
                        width: 82
                    }, {
                        field: "CreateEmployee",
                        title: "建檔人員",
                        width: 120
                    }, {
                        field: "CreateDateTime",
                        title: "建檔時間",
                        format: "{0:yyyy/MM/dd HH:mm}",
                        width: 140
                    }, {
                        field: "ModifyEmployee",
                        title: "異動人員",
                        width: 120
                    }, {
                        field: "ModifyDateTime",
                        title: "異動時間",
                        format: "{0:yyyy/MM/dd HH:mm}",
                        width: 140
                    }
                ]
            });
            //#endregion

            //#region 表格:編輯按鈕
            $(".code-grid").on("click", ".btn-edit", function (e) {
                e.preventDefault();
                var grid = $(this).closest("[data-role='grid']");
                var parentGrid = $(this).closest("[data-role='grid']").parent().closest("[data-role='grid']");

                var dataItem = $(grid).data("kendoGrid").dataItem($(e.currentTarget).closest("tr"));
                if (!parentGrid.hasClass("code-grid"))
                    dataItem.ParentCodeTableName = "根代碼";
                else
                    dataItem.ParentCodeTableName = $(parentGrid).data("kendoGrid").dataItem($(grid).closest("tr").prev()).Name;

                fetchData(dataItem);

                $(".code-window").data("kendoWindow").open();
            });
            //#endregion

            //#region 表格:新增按鈕
            $(".code-grid").on("click", ".btn-insert", function (e) {
                var dataItem = null;
                var currentGrid = $(this).closest("[data-role='grid']");
                var parentGrid = $(this).closest("[data-role='grid']").parent().closest("[data-role='grid']");

                if (currentGrid.hasClass("sub-grid")) {
                    var parentDataItem = parentGrid.data("kendoGrid").dataItem($(this).closest("tr").prev());
                    var orderNo = $.Enumerable.From(parentGrid.data("kendoGrid").dataSource.data()).Max(function (data) { return data.ParentCodeTableId == parentDataItem.CodeTableId ? data.OrderNo : 0; }) + 1;
                    dataItem = {
                        ParentCodeTableName: parentDataItem.Name,
                        ParentCodeTableId: parentDataItem.CodeTableId,
                        CodeTableId: null,
                        OrderNo: orderNo
                    };
                } else {
                    var orderNo = $.Enumerable.From(currentGrid.data("kendoGrid").dataSource.data()).Max(function (data) { return data.ParentCodeTableId == null ? data.OrderNo : 0; }) + 1;
                    dataItem = { ParentCodeTableName: "根代碼", ParentCodeTableId: null, CodeTableId: null, OrderNo: orderNo };
                }

                fetchData(dataItem);

                $(".code-window").data("kendoWindow").open();
            });
            //#endregion

            //#region 表格:刪除按鈕
            $(".code-grid").on("click", ".btn-delete", function (e) {
                var selectDataItem = [];
                var grid = $(this).closest("[data-role='grid']").data("kendoGrid");

                $.each(grid.select(), function (index, row) {
                    var dataItem = $(".code-grid").data("kendoGrid").dataItem(row);

                    if (!$.Enumerable.From(selectDataItem).Any(function (data) { return data.CodeTableId == dataItem.CodeTableId; }))
                        selectDataItem.push(dataItem);
                });

                $.block(".div-content");

                $.ajax({
                    contentType: "application/json",
                    dataType: "json",
                    data: kendo.stringify(selectDataItem),
                    type: "post",
                    url: codetable_delete_url,
                    complete: function () {
                        $.unblock(".div-content");
                    },
                    success: function (result) {
                        if (result) {
                            $.alert("刪除成功", "success");
                            $(".code-grid").data("kendoGrid").dataSource.read();
                            $(".code-window").data("kendoWindow").close();
                        } else
                            $.alert("刪除失敗", "error");
                    },
                    error: function () {
                        $.alert("連線至伺服器失敗，請重新登入系統", "error");
                    }
                });
            });
            //#endregion

            //#region 表格:核取方塊
            $(".code-grid .k-grid-content").on("click", "input.delete-check-box", function (e) {
                var checked = this.checked;
                var row = $(this).closest("tr");
                var grid = $("#grid").data("kendoGrid");
                var dataItem = grid.dataItem(row);

                checkedIds[dataItem.id] = checked;
                if (checked)
                    row.addClass("k-state-selected");
                else
                    row.removeClass("k-state-selected");
            });
            //#endregion

            //#region 初始工具列
            function initialToolbar() {
                //#region 新增按鈕
                $(".btn-insert").kendoButton({
                    icon: "add"
                });
                //#endregion

                //#region 刪除按鈕
                $(".btn-delete").kendoButton({
                    icon: "delete"
                });
                //#endregion
            }
            //#endregion

            //#endregion

            //#region 代碼視窗
            var validator = $(".code-window").kendoValidator().data("kendoValidator");

            //#region 初始順序
            $(".code-window").find("#txtOrderNo").kendoNumericTextBox({
                format: "n0",
                min: 1,
                value: 1
            });
            //#endregion

            //#region 初始整數設定值
            $("#txtIntegerName").kendoNumericTextBox({
                format: "n0",
                value: 0
            });
            //#endregion

            //#region 初始數值設定值
            $("#txtDecimalName").kendoNumericTextBox({
                format: "n",
                value: 0.0
            });
            //#endregion

            //#region 初始日期設定值
            $("#txtDateName").kendoDatePicker({
                format: "yyyy/MM/dd",
                value: new Date()
            });
            //#endregion

            //#region 初始日期時間設定值
            $("#txtDateTimeName").kendoDateTimePicker({
                format: "yyyy/MM/dd HH:mm",
                value: new Date()
            });
            //#endregion

            //#region 初始代碼視窗
            $(".code-window").kendoWindow({
                width: "1200px",
                title: "代碼",
                visible: false,
                actions: [
                    "Minimize",
                    "Maximize",
                    "Close"
                ]
            }).data("kendoWindow").center();
            //#endregion

            //#region 初始代碼類型
            $("#ddlCodeType").kendoDropDownList({
                dataSource: {
                    sort: { field: "Name", dir: "asc" },
                    transport: {
                        read: function (options) {
                            $.ajax({
                                contentType: "application/json",
                                dataType: "json",
                                type: "post",
                                url: codetype_dropdown_url,
                                success: function (result) {
                                    //取得列舉類型識別碼
                                    enum_code_type_id = $.Enumerable.From(result).First(function (codeType) { return codeType.Code == "Enum"; }).CodeTableId;

                                    options.success(result);

                                    $(".code-grid").data("kendoGrid").dataSource.read();
                                },
                                error: function (data) { $.alert("查詢錯誤", "error"); }
                            });
                        }
                    }
                },
                change: function (e) {
                    fetchCodeType(null);
                },
                select: function (e) {
                    if (e.dataItem.Code == "hidden")
                        e.preventDefault();
                },
                autoBind: isQuery,
                dataTextField: "Name",
                dataValueField: "CodeTableId",
                template: kendo.template($("#codetype-template").html())
            });
            //#endregion

            //#region 初始角色
            $("#ddlPermissionCode").kendoMultiSelect({
                dataSource: {
                    sort: { field: "text", dir: "asc" },
                    transport: {
                        read: function (options) {
                            $.ajax({
                                contentType: "application/json",
                                dataType: "json",
                                data: kendo.stringify({ Source: "Role" }),
                                type: "post",
                                url: relation_query_filter_url,
                                success: function (result) { options.success(result); },
                                error: function (data) { $.alert("查詢錯誤", "error"); }
                            });
                        }
                    }
                },
                autoBind: true,
                dataTextField: "text",
                dataValueField: "value"
            });
            //#endregion

            //#region 儲存按鈕
            $(".btn-save").kendoButton({
                icon: "save",
                click: function (e) {
                    e.preventDefault();

                    if (!validator.validate()) {
                        $.alert("請輸入完整代碼資訊", "error");
                        return;
                    }

                    $.block(".code-window");

                    $.ajax({
                        contentType: "application/json",
                        dataType: "json",
                        data: getData(),
                        type: "post",
                        url: codetable_update_url,
                        complete: function () {
                            $.unblock(".code-window");
                        },
                        success: function (result) {
                            if (result) {
                                $.alert("儲存成功", "success");
                                $(".code-grid").data("kendoGrid").dataSource.read();
                                $(".code-window").data("kendoWindow").close();
                            } else
                                $.alert("儲存失敗", "error");
                        },
                        error: function () {
                            $.alert("連線至伺服器失敗，請重新登入系統", "error");
                        }
                    });
                }
            });
            //#endregion

            //#region 取消按鈕
            $(".btn-cancel").kendoButton({
                icon: "cancel",
                click: function () {
                    $(".code-window").data("kendoWindow").close();
                }
            });
            //#endregion

            //#endregion

            //#region 自訂方法

            //#region 顯示資料至代碼視窗
            function fetchData(data) {
                if (data.ParentCodeTableId == null) {
                    $(".code-window").removeData("parent-code-table-id");
                    $.each($(".code-window").find("#ddlCodeType").data("kendoDropDownList").dataSource.data(), function (index, data) {
                        if (data.CodeTableId == enum_code_type_id)
                            data.Code = "Enum";
                    });
                } else {
                    $(".code-window").data("parent-code-table-id", data.ParentCodeTableId);
                    $.each($(".code-window").find("#ddlCodeType").data("kendoDropDownList").dataSource.data(), function (index, data) {
                        if (data.CodeTableId == enum_code_type_id)
                            data.Code = "hidden";
                    });
                }
                $(".code-window").find("#ddlCodeType").data("kendoDropDownList").refresh();

                if (data.CodeTableId == null) {
                    if (data.ParentCodeTableId == null)
                        $(".code-window").data("kendoWindow").title("新增根代碼");
                    else {
                        $(".code-window").data("kendoWindow").title("新增子代碼 - " + data.ParentCodeTableName);
                    }
                    $(".code-window").find("#ddlCodeType").data("kendoDropDownList").readonly(false);
                    $(".code-window").find("#txtCode").removeAttr("readonly");
                    $(".code-window").find("#txtCode").removeClass("readonly");
                    $(".code-window").removeData("code-table-id");
                    $(".code-window").find(".create-row").hide();
                    $(".code-window").find(".modify-row").hide();
                } else {
                    if (data.ParentCodeTableId == null)
                        $(".code-window").data("kendoWindow").title("編輯根代碼 - " + data.Name);
                    else
                        $(".code-window").data("kendoWindow").title("編輯子代碼 - " + data.ParentCodeTableName + "\\" + data.Name);
                    $(".code-window").find("#ddlCodeType").data("kendoDropDownList").readonly(true);
                    $(".code-window").find("#txtCode").attr("readonly", "readonly");
                    $(".code-window").find("#txtCode").addClass("readonly");
                    $(".code-window").data("code-table-id", data.CodeTableId);
                    $(".code-window").find(".create-row").show();
                    $(".code-window").find(".modify-row").show();
                }

                $(".code-window").find("#txtParentCodeTableName").val(data.ParentCodeTableName);
                $(".code-window").data("menuid", data.CodeTableId);
                if (data.CodeTypeId != null)
                    $(".code-window").find("#ddlCodeType").data("kendoDropDownList").value(data.CodeTypeId);
                else
                    $(".code-window").find("#ddlCodeType").data("kendoDropDownList").select(0);
                $(".code-window").find("#txtCode").val(data.Code);

                fetchCodeType(data.Name);

                $(".code-window").find("#txtMemo").val(data.Memo);
                $(".code-window").find("#txtOrderNo").data("kendoNumericTextBox").value(data.OrderNo);
                if (data.PermissionCodes != null)
                    $(".code-window").find("#ddlPermissionCode").data("kendoMultiSelect").value(data.PermissionCodes.split(","));
                else
                    $(".code-window").find("#ddlPermissionCode").data("kendoMultiSelect").value("");
                if (data.CreateEmployeeId != null)
                    $(".code-window").find("#txtCreateInfo").val(data.CreateEmployee + " 於 " + kendo.toString(data.CreateDateTime, "yyyy/MM/dd HH:mm") + " 建檔");
                else
                    $(".code-window").find("#txtCreateInfo").val("");
                if (data.ModifyEmployeeId != null)
                    $(".code-window").find("#txtModifyInfo").val(data.ModifyEmployee + " 於 " + kendo.toString(data.ModifyDateTime, "yyyy/MM/dd HH:mm") + " 異動");
                else
                    $(".code-window").find("#txtModifyInfo").val("");
            }
            //#endregion

            //#region 顯示代碼類型
            function fetchCodeType(value) {
                $(".code-window").find("#txtName").hide();
                $(".code-window").find("#txtName").removeAttr("required");
                $(".code-window").find("#txtIntegerName").data("kendoNumericTextBox").wrapper.hide();
                $(".code-window").find("#txtIntegerName").removeAttr("required");
                $(".code-window").find("#txtDecimalName").data("kendoNumericTextBox").wrapper.hide();
                $(".code-window").find("#txtDecimalName").removeAttr("required");
                $(".code-window").find("#txtDateName").data("kendoDatePicker").wrapper.hide();
                $(".code-window").find("#txtDateName").removeAttr("required");
                $(".code-window").find("#txtDateTimeName").data("kendoDateTimePicker").wrapper.hide();
                $(".code-window").find("#txtDateTimeName").removeAttr("required");

                switch ($(".code-window").find("#ddlCodeType").data("kendoDropDownList").dataItem().Code) {
                    case "Integer":
                        $(".code-window").find("#txtIntegerName").attr("required", "true");
                        $(".code-window").find("#txtIntegerName").data("kendoNumericTextBox").wrapper.show();
                        $(".code-window").find("#txtIntegerName").data("kendoNumericTextBox").value(value);
                        break;
                    case "Decimal":
                        $(".code-window").find("#txtDecimalName").attr("required", "true");
                        $(".code-window").find("#txtDecimalName").data("kendoNumericTextBox").wrapper.show();
                        $(".code-window").find("#txtDecimalName").data("kendoNumericTextBox").value(value);
                        break;
                    case "Date":
                        $(".code-window").find("#txtDateName").attr("required", "true");
                        $(".code-window").find("#txtDateName").data("kendoDatePicker").wrapper.show();
                        $(".code-window").find("#txtDateName").data("kendoDatePicker").value(value);
                        break;
                    case "DateTime":
                        $(".code-window").find("#txtDateTimeName").attr("required", "true");
                        $(".code-window").find("#txtDateTimeName").data("kendoDateTimePicker").wrapper.show();
                        $(".code-window").find("#txtDateTimeName").data("kendoDateTimePicker").value(value);
                        break;
                    default:
                        $(".code-window").find("#txtName").attr("required", "true");
                        $(".code-window").find("#txtName").show();
                        $(".code-window").find("#txtName").val(value);
                        break;
                }
            }
            //#endregion

            //#region 取得選單視窗資料
            function getData() {
                return kendo.stringify({
                    CodeTableId: $(".code-window").data("code-table-id"),
                    ParentCodeTableId: $(".code-window").data("parent-code-table-id"),
                    CodeTypeId: $(".code-window").find("#ddlCodeType").data("kendoDropDownList").value(),
                    Code: $(".code-window").find("#txtCode").val(),
                    Name: getName(),
                    Memo: $(".code-window").find("#txtMemo").val(),
                    OrderNo: $(".code-window").find("#txtOrderNo").data("kendoNumericTextBox").value(),
                    PermissionCodes: $(".code-window").find("#ddlPermissionCode").data("kendoMultiSelect").value().toString()
                });
            }
            //#endregion

            //#region 取得代碼設定值
            function getName() {
                switch ($(".code-window").find("#ddlCodeType").data("kendoDropDownList").dataItem().Code) {
                    case "Integer":
                        return $(".code-window").find("#txtIntegerName").data("kendoNumericTextBox").value();
                    case "Decimal":
                        return $(".code-window").find("#txtDecimalName").data("kendoNumericTextBox").value();
                    case "Date":
                        return kendo.toString($(".code-window").find("#txtDateName").data("kendoDatePicker").value(), "yyyy/MM/dd");
                    case "DateTime":
                        return kendo.toString($(".code-window").find("#txtDateTimeName").data("kendoDateTimePicker").value(), "yyyy/MM/dd HH:mm");
                    default:
                        return $(".code-window").find("#txtName").val();
                }
            }
            //#endregion

            //#endregion
        });
    </script>
}
<!-- #region 主畫面 -->
<div class="result k-card" style="margin-top: 1px;">
    <div class="k-card-body">
        <div class="code-grid"></div>
    </div>
</div>
<!-- #endregion -->
<!-- #region 代碼視窗 -->
<div class="code-window">
    <div class="search k-card" style="margin-top: 5px;">
        <div class="k-grid k-content k-grid-display-block container">
            <div class="k-card-body">
                <div class="row">
                    <div class="col-sm-2 k-header">
                        <label for="txtCode">上層名稱</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <input type="text" class="k-textbox readonly" id="txtParentCodeTableName" name="txtParentCodeTableName" readonly />
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-2 k-header">
                        <span style="color: red;">*</span>&nbsp;<label for="ddlCodeType">代碼類型</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <select id="ddlCodeType" name="ddlCodeType"></select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-2 k-header">
                        <span style="color: red;">*</span>&nbsp;<label for="txtCode">代碼</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <input type="text" class="k-textbox" id="txtCode" name="txtCode" placeholder="代碼" required validationMessage="請輸入代碼" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-2 k-header">
                        <span style="color: red;">*</span>&nbsp;<label for="txtName">名稱/設定值</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <input type="text" class="k-textbox" id="txtName" name="txtName" placeholder="名稱" required validationMessage="請輸入名稱" />
                        <input id="txtIntegerName" name="txtIntegerName" required />
                        <input id="txtDecimalName" name="txtDecimalName" required />
                        <input id="txtDateName" name="txtDateName" required />
                        <input id="txtDateTimeName" name="txtDateTimeName" required />
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-2 k-header">
                        <label for="txtMemo">說明</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <textarea id="txtMemo" class="k-textbox" rows="3"></textarea>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-2 k-header">
                        <span style="color: red;">*</span>&nbsp;<label for="txtOrderNo">順序</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <input type="text" id="txtOrderNo" required />
                    </div>
                </div>
                <div class="row" style="display: none;">
                    <div class="col-sm-2 k-header">
                        <label for="ddlPermissionCode">授權角色</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <select id="ddlPermissionCode" name="ddlPermissionCode"></select>
                        <span style="color: blue;">註：未設定表示所有擁有代碼維護權限之角色皆可維護</span>
                    </div>
                </div>
                <div class="row create-row">
                    <div class="col-sm-2 k-header">
                        <label for="txtCreateInfo">建檔資訊</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <input type="text" class="k-textbox readonly" id="txtCreateInfo" readonly="readonly" />
                    </div>
                </div>
                <div class="row modify-row">
                    <div class="col-sm-2 k-header">
                        <label for="txtModifyInfo">異動資訊</label>
                    </div>
                    <div class="col-sm-10 k-cell">
                        <input type="text" class="k-textbox readonly" id="txtModifyInfo" readonly="readonly" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12 text-center">
                        @if (isSave)
                        {
                            <button class="btn-save k-primary">儲存</button>
                        }
                        <button class="btn-cancel">取消</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- #endregion -->
<!-- #region 樣板 -->
<!-- #region 關聯設定樣板 -->
<script id="command-template" type="text/x-kendo-template">
    @if (isSave)
    {
        <button class="k-button btn-edit">編輯</button>
    }
</script>
